{
  "name": "Frontend",
  "dockerComposeFile": ["../../compose.yaml", "../../compose.override.yaml"],
  "service": "frontend",
  "workspaceFolder": "/usr/src/app",
  "forwardPorts": [3000],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "remoteUser": "root",
  "updateRemoteUserUID": true,
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,readonly",
    "source=${localEnv:HOME}/.aws,target=/root/.aws,type=bind,readonly",
    "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/root/.claude.json,type=bind",
    "source=claude-code-local-${devcontainerId},target=/root/.local,type=volume"
  ],
  "remoteEnv": {
    "PATH": "/root/.local/bin:${containerEnv:PATH}"
  },
  "postCreateCommand": "apk add --no-cache bash libgcc libstdc++ ripgrep curl git && export PATH=/root/.local/bin:$PATH && which claude || curl -fsSL https://claude.ai/install.sh | bash"
}