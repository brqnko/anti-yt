{
  "name": "Frontend",
  "dockerComposeFile": ["../../compose.yaml", "../../compose.override.yaml"],
  "service": "frontend",
  "workspaceFolder": "/usr/src/app",
  "forwardPorts": [3000],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "remoteUser": "root",
  "updateRemoteUserUID": true
}