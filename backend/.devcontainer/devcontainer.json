{
  "name": "Backend",
  "dockerComposeFile": ["../../compose.yaml", "../../compose.override.yaml", "docker-compose.devcontainer.yaml"],
  "service": "server",
  "workspaceFolder": "/src",
  "forwardPorts": [8080],
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "rajasunrise.sqlc-snippets",
        "ckolkman.vscode-postgres"
      ]
    }
  },
  "overrideCommand": false,
  "features": {
  },
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,readonly",
    "source=${localEnv:HOME}/.aws,target=/root/.aws,type=bind,readonly",
    "source=claude-code-local-${devcontainerId},target=/root/.local,type=volume"
  ],
  "remoteEnv": {
    "PATH": "/root/.local/bin:${containerEnv:PATH}"
  },
  "postCreateCommand": ""
}
